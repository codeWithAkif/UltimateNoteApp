<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_item_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:gravity="center_vertical">

    <ImageView
        android:id="@+id/item_status"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:src="@drawable/widget_unchecked"
        android:layout_marginEnd="12dp"
        android:contentDescription="Status" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/item_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alışveriş öğesi"
            android:textColor="#f1f5f9"
            android:textSize="14sp" />

        <LinearLayout
            android:id="@+id/layout_badge_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="3dp"
            android:gravity="center_vertical"
            android:visibility="gone">
            
            <TextView
                android:id="@+id/tv_widget_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/recurrence_input_bg"
                android:textColor="#38bdf8"
                android:textSize="11sp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:text="Badges" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/item_delete"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✕"
        android:textColor="#64748b"
        android:textSize="14sp"
        android:paddingStart="12dp"
        android:paddingEnd="4dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:textStyle="bold" />
</LinearLayout>
