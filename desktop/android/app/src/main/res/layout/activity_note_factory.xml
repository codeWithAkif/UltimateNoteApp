<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/quick_add_card_bg"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="16dp"
    android:paddingBottom="12dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hızlı Not Fabrikası"
        android:textColor="#ffffff"
        android:textSize="15sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp" />

    <EditText
        android:id="@+id/note_factory_input"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@null"
        android:hint="Aklındakileri yaz... (@klasör !not #etiket)"
        android:textColorHint="#4b5563"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:imeOptions="actionDone"
        android:inputType="textCapSentences|textMultiLine"
        android:maxLines="6"
        android:minLines="2"
        android:gravity="top" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/note_factory_chips_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/chip_folder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/datetime_badge_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="📂 Klasör"
                android:textColor="#38bdf8"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/chip_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/datetime_badge_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="📄 Not"
                android:textColor="#fbbf24"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/chip_todo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="6dp"
                android:background="@drawable/datetime_badge_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="☑️ Görev"
                android:textColor="#c084fc"
                android:textSize="11sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/chip_tags"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/datetime_badge_bg"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="🏷️ Etiketler"
                android:textColor="#34d399"
                android:textSize="11sp"
                android:visibility="gone" />
        </LinearLayout>
    </HorizontalScrollView>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#252d3a"
        android:layout_marginBottom="8dp" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">

            <TextView
                android:id="@+id/btn_insert_folder"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="14dp"
                android:background="@drawable/datetime_badge_bg"
                android:backgroundTint="#252d3a"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="@ Klasör"
                android:textColor="#9ca3af"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_insert_note"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="14dp"
                android:background="@drawable/datetime_badge_bg"
                android:backgroundTint="#252d3a"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="! Not"
                android:textColor="#9ca3af"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_insert_tag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="14dp"
                android:background="@drawable/datetime_badge_bg"
                android:backgroundTint="#252d3a"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="# Etiket"
                android:textColor="#9ca3af"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/btn_insert_todo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/datetime_badge_bg"
                android:backgroundTint="#252d3a"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="#todo"
                android:textColor="#9ca3af"
                android:textSize="12sp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <TextView
            android:id="@+id/btn_note_factory_save"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="Gönder"
            android:textColor="#64748b"
            android:textSize="14sp"
            android:textStyle="bold"
            android:clickable="false"
            android:focusable="true"
            android:padding="6dp" />
    </RelativeLayout>
</LinearLayout>
